{
  "id": "session-deck-demo",
  "name": "Session Deck Demo",
  "version": "0.1.0",
  "description": "Example frontend plugin that renders RelayDesk session context and calls host RPC methods.",
  "capabilities": ["demo", "frontend", "sessions"],
  "tabTitle": "Session Deck",
  "routeSegment": "session-deck-demo",
  "frontend": {
    "type": "local_bundle",
    "apiVersion": "1.0",
    "displayName": "Session Deck Demo",
    "entry": "./session-deck.bundle.js"
  },
  "frontendComponent": "project_pulse",
  "backendService": "rpc_bridge",
  "actions": [],
  "rpcMethods": [
    {
      "id": "context-snapshot",
      "label": "Load context snapshot",
      "description": "Read the current RelayDesk host context.",
      "handler": "get_context_snapshot",
      "inputs": [],
      "permissions": ["read_host_context"]
    },
    {
      "id": "task-board",
      "label": "Load task board",
      "description": "Read the current TaskMaster board.",
      "handler": "list_task_board",
      "inputs": [],
      "permissions": ["read_host_context"]
    }
  ]
}
